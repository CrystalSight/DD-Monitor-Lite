{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DD Monitor Lite",
  "version": "0.1.0",
  "identifier": "com.ddmonitor.lite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DD Monitor Lite",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "custom:", "asset:"],
        "img-src": [
          "'self'",
          "data:",
          "asset:",
          "https://*.hdslb.com",
          "https://*.bilibili.com"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
